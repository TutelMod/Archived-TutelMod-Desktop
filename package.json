{
  "name": "tutelmod-desktop",
  "author": "TutelMod",
  "description": "The desktop version of TutelMod!",
  "version": "1.0.0",
  "main": "app/electron-main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:fast": "electron-builder --config.compression=store --publish never --dir"
  },
  "build": {
    "appId": "com.tutelmod.desktop",
    "productName": "TutelMod Desktop",
    "directories": {
      "output": "builds"
    },
    "files": [
      "app/**/*"
    ],
    "compression": "maximum",
    "publish": null,
    "buildDependenciesFromSource": false,
    "asar": false,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "linux": {
      "compression": "normal",
      "category": "Development",
      "maintainer": "vedal789",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64",
            "armv7l"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64",
            "armv7l"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64",
            "armv7l"
          ]
        }
      ]
    },
    "deb": {
      "compression": "xz"
    },
    "rpm": {
      "compression": "xz"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        }
      ],
      "signAndEditExecutable": true,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TutelMod Desktop"
    }
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "dependencies": {
    "unzipper": "^0.12.3"
  }
}
